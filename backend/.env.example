# ─── GhostRent Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Copy URI
# Replace <username> and <password> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ── Authentication ───────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_long_random_secret_here
JWT_EXPIRES_IN=7d

# ── Groq AI (LLM) ────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_api_key_here

# Leave these as-is unless Groq changes them
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# ── CORS (optional) ──────────────────────────────────────────────────────────────
# Set to your frontend URL in production (e.g., https://ghostrent.vercel.app)
# Leave blank or omit to allow all origins (fine for local development)
# CLIENT_ORIGIN=https://your-frontend-url.com